# --- Model (Gemini Flash 3 Lite) ---
GEMINI_API_KEY=
# Override the exact model id if needed (default: gemini-flash-lite-latest)
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_TEMPERATURE=0.1

# --- Retrieval (contour 3) ---
TAVILY_API_KEY=

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Cost estimation (optional; USD per 1M tokens) ---
# GEMINI_INPUT_PRICE_1M=0.10
# GEMINI_OUTPUT_PRICE_1M=0.40
